{
    "sales": {
        "take": 100,
        "skip": 0,
        "dateStartKey": "dateSaleStart",
        "dateEndKey": "dateSaleEnd",
        "responseKey": null,
        "idField": "idSale",
        "colunas_drop": [
            "idemployee", "nameemployee", "idprospect", "idresponsible",
            "idmemberresponsible", "cpfresponsible", "saledateserver", "timezone",
            "idpersonal", "removed", "idemployeeremoval", "removaldate",
            "salesource", "idsalemigration", "idcarttoken", "prospect",
            "receivables", "member_document", "member_country", "member_address",
            "member_state", "member_city", "member_passport", "member_zipcode", 
            "member_complement", "member_neighborhood", "member_number", "member_idmembermigration",
            "observations", "idsalerecurrency", "registrationkind", "member_idmember",
            "member_registername", "member_registerlastname", "member_usepreferredname",
            "member_registrationkind", "member_idfirstmembermembership", "member_diasrenovacao"
],
        "colunas_explode": ["saleitens", "member_contacts", "member_responsibles"],
        "sub_tables": {
            "saleitens": {
                "colunas_drop": [
                    "description", "nummembers", "idproduct", "idservice", "discount", "corporatepartnershipname",
                    "coporatepartnershipid", "corporatediscount", "tax", "voucher",
                    "accountingcode", "municipalservicecode", "flreceiptonly", "idsaleitemmigration",
                    "flswimming", "flallowlocker"
                ],
                "colunas_regex": {
                    "item": {"pattern": "\\d+,\\d+\\s*|\\b\\d{1,3}\\b", "replacement": ""}
                }
            },
            "member_contacts": {
                "colunas_drop": [
                    "idemployee", "idprospect", "idprovider"
                ]
            },
            "member_responsibles": {
                "colunas_drop": [
                    "idmemberresponsible", "acessfiti", "financialresponsible", "persontype",
                    "document", "cep", "adress", "number", "complement", "district", "city", "state"
                ]
            }
        },
        "branches": {
            "filial_01": { "idBranch": 0 },
            "filial_02": { "idBranch": 0 }
        }
    },
    "debtors": {
        "take": 50,
        "skip": 0,
        "dateStartKey": "registrationDateStart",
        "dateEndKey": "registrationDateEnd",
        "responseKey": "results",
        "idField": "receivableId",
        "colunas_drop": ["checkoutlink", "checkoutlinkfulldebt", "lastacquirerdeclinereason"],
        "colunas_explode": [],
        "branches": {
            "filial_01": { "idBranch": 0 },
            "filial_02": { "idBranch": 0 }
        }
    },
    "membership": {
        "take": 50,
        "skip": 0,
        "dateStartKey": "updateDate",
        "dateEndKey": null,
        "responseKey": null,
        "idField": "idMembership",
        "colunas_drop": [
            "minperiodstaymembership"
        ],
        "colunas_explode": ["differentials", "accessbranches", "salespage"],
        "branches": {
            "filial_01": { "idBranch": null },
            "filial_02": { "idBranch": null }
        }
    },
    "membership_category": {
        "take": 50,
        "skip": 0,
        "dateStartKey": null,
        "dateEndKey": null,
        "responseKey": null,
        "idField": "idCategoryMembership",
        "colunas_drop": [],
        "colunas_explode": [],
        "branches": {
            "filial_01": { "idBranch": null },
            "filial_02": { "idBranch": null }
        }
    },
    "membermembership": {
        "take": 25,
        "skip": 0,
        "dateStartKey": null,
        "dateEndKey": null,
        "responseKey": null,
        "idField": "idMember",
        "colunas_drop": [],
        "colunas_explode": ["receivables"],
        "branches": {
            "filial_01": { "idBranch": null },
            "filial_02": { "idBranch": null }
        }
    },
    "members": {
        "take": 50,
        "skip": 0,
        "dateStartKey": "registerDateStart",
        "dateEndKey": "registerDateEnd",
        "responseKey": null,
        "idField": "idMember",
        "colunas_drop": [
                "address", "neighborhood", "accesscardnumber", "membershipstatus",
                "memberships", "idemployeepersonaltrainer", "nameemployeepersonaltrainer", "idmembermigration",
                "responsibles", "personaltype", "cref", "crefexpirationdate",
                "useridgurupass"
],
        "colunas_explode": ["contacts"],
        "branches": {
            "filial_01": { "idBranch": null },
            "filial_02": { "idBranch": null }
        }
    },
    "prospects": {
        "take": 50,
        "skip": 0,
        "dateStartKey": "registerDateStart",
        "dateEndKey": "registerDateEnd",
        "responseKey": null,
        "idField": "idProspect",
        "colunas_drop": [
            "rg", "conversiondate", "idmember", "currentstep", "address", "city", "complement",
            "neighborhood", "state", "country", "zipcode", "number", "interests", "financiallyresponsibles"
        ],
        "colunas_explode": [],
        "branches": {
            "filial_01": { "idBranch": null },
            "filial_02": { "idBranch": null }
        }
    }
}

